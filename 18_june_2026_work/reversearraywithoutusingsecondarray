#include<stdio.h>
int main(){
    int arr[5]={2,5,9,4,3};
    int size=5;
    int temp,i;
    printf("the original array is:\n");
    for(i=0;i<size;i++){
        printf("%d ",arr[i]);
    }
    for(i=0;i<size/2;i++){
        temp=arr[i];
        arr[i]=arr[size-i-1];
        arr[size-i-1]=temp;

    }
    printf("the reversed array is:\n");
        for(i=0;i<size;i++){
            printf("%d ",arr[i]);
        }
        return 0;
    }
    


